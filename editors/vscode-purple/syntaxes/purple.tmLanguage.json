{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Purple",
  "scopeName": "source.purple",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#multi" },
    { "include": "#number" },
    { "include": "#model-name" },
    { "include": "#query-name" },
    { "include": "#fn-name" },
    { "include": "#tyre" },
    { "include": "#bool" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.purple",
          "match": "//.*"
        }
      ]
    },
    "string": {
      "name": "string.quoted.double.purple",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.purple",
          "match": "\\\\."
        }
      ]
    },
    "multi": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.purple",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.arrow.purple",
          "match": "->"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.purple",
          "match": "\\b\\d+\\.\\d*\\b|\\b\\d*\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.purple",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "model-name": {
      "match": "\\b(model)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.purple" },
        "2": { "name": "entity.name.type.purple" }
      }
    },
    "query-name": {
      "match": "\\b(query)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.purple" },
        "2": { "name": "entity.name.function.purple" }
      }
    },
    "fn-name": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.purple" },
        "2": { "name": "entity.name.function.purple" }
      }
    },
    "tyre": {
      "match": "\\b(SOFT|MEDIUM|HARD|INTER|WET)\\b",
      "name": "constant.other.tyre.purple"
    },
    "bool": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.purple"
    },
    "keyword": {
      "patterns": [
        {
          "match": "\\b(let|require|return|if)\\b",
          "name": "keyword.control.purple"
        },
        {
          "match": "\\b(and|or|not)\\b",
          "name": "keyword.operator.logical.purple"
        }
      ]
    },
    "type": {
      "match": "\\b(int|float|bool|string|compound|seconds|percent|fuel|distance|lap|position)\\b",
      "name": "storage.type.purple"
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.purple",
          "match": "[+\\-*/=;:.,<>!]"
        }
      ]
    }
  }
}
